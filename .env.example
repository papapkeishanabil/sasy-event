# Supabase Configuration (Required for cross-device sync)
# Get these values from https://supabase.com
# 1. Create a new project at https://supabase.com
# 2. Go to Project Settings > API
# 3. Copy the URL and anon/public key

VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Firebase Configuration (Optional - Deprecated, use Supabase instead)
# Uncomment and fill these values to enable real-time sync

# VITE_FIREBASE_API_KEY=your_api_key_here
# VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
# VITE_FIREBASE_PROJECT_ID=your_project_id
# VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
# VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
# VITE_FIREBASE_APP_ID=your_app_id
